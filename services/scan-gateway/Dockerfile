FROM python:3.12-slim

WORKDIR /app

COPY services/scan-gateway/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY shared ./shared
COPY services/scan-gateway ./service

ENV PYTHONPATH=/app/shared

WORKDIR /app/service

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
